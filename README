При запуске worker 

Ошибка MODULE_NOT_FOUND означает, что файла worker-js.js физически нет в директории backend.

Исправление
1. Создать файл
В папке backend создать файл:

worker-js.js
Структура должна быть:

backend/
 ├─ server.js
 ├─ worker-js.js
 ├─ package.json
2. Вставить код воркера
Открыть worker-js.js и вставить код, который был дан ранее.

3. Запуск
node worker-js.js
Альтернатива (чистая архитектура)
Разделить сервисы:

project/
 ├─ backend/   → server.js
 ├─ worker/    → worker-js.js
Тогда:

cd worker
npm init -y
npm install express minio @babel/parser @babel/traverse
node worker-js.js
Суть ошибки
Node.js ищет файл по пути:

C:\...\backend\worker-js.js
и не находит его. Это не ошибка зависимостей, а отсутствие файла.


{
    "error": "connect EACCES ::1:4001"
}

Ошибка EACCES ::1:4001 указывает, что сервер не может подключиться к воркеру на IPv6 ::1 (localhost), порт 4001. Причины:

Воркер не запущен.

Проверь node worker-js.js и убедись, что вывод:

Worker started on 4001
Порт заблокирован или используется другим процессом.

Проверить командой в PowerShell:

netstat -ano | findstr 4001
Если занят, убить процесс:

taskkill /PID <pid> /F
Node пытается подключиться по IPv6 (::1), а воркер слушает IPv4 (127.0.0.1).

Исправить в server.js:

// axios.post('http://localhost:4001/process', {...})
// заменить на
axios.post('http://127.0.0.1:4001/process', {...})
или в воркере слушать на всех интерфейсах:

app.listen(4001, '::', async () => {
  await init()
  console.log('Worker started on 4001')
})
После исправления:

Запусти воркер node worker-js.js.

Убедись, что он слушает 4001 на 127.0.0.1.

Запусти сервер node server.js.

Отправь файл.

Соединение должно пройти.


В целом оно работает

Система работает:

сервер пишет в preprocessed с дедупликацией,

воркер читает файл, анализирует AST, пишет JSON в processed_files,

сервер получает имя обработанного JSON.

Все процессы асинхронны, масштабируются горизонтально, файл между сервисами не передаётся, передаются только ссылки на MinIO.


В целом оно работает но меня не устраивает то как оно работает, мне же прям надо функционал обернутый в AST, а не просто сколько у меня чего, надо прям зависимости подтянуть, надо чтобы связь функций отображалась их названия и тд кароче что то типа вот такого, кароче развёрнутый продвинутую

Понял. Нужно перейти от простых счетчиков к полноценному анализу AST с построением графа зависимостей функций, переменных, импортов, включая:

имена функций и стрелочных функций, их аргументы

вызовы функций внутри функций (связи)

зависимости через import и require

глобальные переменные

вложенные функции

Результат — JSON с деревом и графовыми связями, который можно сразу сохранить в MinIO (processed_files).

Ниже пример продвинутого воркера для Node.js:

const express = require('express')
const Minio = require('minio')
const parser = require('@babel/parser')
const traverse = require('@babel/traverse').default

const app = express()
app.use(express.json())

const minioClient = new Minio.Client({
  endPoint: '127.0.0.1',
  port: 9000,
  useSSL: false,
  accessKey: 'admin',
  secretKey: 'strongpassword'
})

const OUT_BUCKET = 'processed_files'

async function init() {
  const exists = await minioClient.bucketExists(OUT_BUCKET).catch(() => false)
  if (!exists) await minioClient.makeBucket(OUT_BUCKET)
}

async function getFile(bucket, objectName) {
  const stream = await minioClient.getObject(bucket, objectName)
  return new Promise((resolve, reject) => {
    const chunks = []
    stream.on('data', c => chunks.push(c))
    stream.on('end', () => resolve(Buffer.concat(chunks)))
    stream.on('error', reject)
  })
}

// AST graph builder
function analyzeAST(code) {
  const ast = parser.parse(code, {
    sourceType: 'unambiguous',
    plugins: ['jsx', 'typescript']
  })

  const graph = {
    functions: {}, // {name: {params: [], calls: [], parent: null}}
    imports: [],
    requires: [],
    variables: []
  }

  const currentFunctionStack = []

  traverse(ast, {
    FunctionDeclaration(path) {
      const name = path.node.id?.name || '<anonymous>'
      const params = path.node.params.map(p => p.name || '<unknown>')
      const parent = currentFunctionStack[currentFunctionStack.length - 1] || null

      graph.functions[name] = { params, calls: [], parent }

      currentFunctionStack.push(name)
    },
    ArrowFunctionExpression(path) {
      const name = path.node.id?.name || '<arrow>'
      const params = path.node.params.map(p => p.name || '<unknown>')
      const parent = currentFunctionStack[currentFunctionStack.length - 1] || null

      graph.functions[name] = { params, calls: [], parent }
      currentFunctionStack.push(name)
    },
    CallExpression(path) {
      const callee = path.node.callee.name || path.node.callee?.property?.name || '<unknown>'
      const currentFn = currentFunctionStack[currentFunctionStack.length - 1]
      if (currentFn) {
        graph.functions[currentFn].calls.push(callee)
      }
      if (path.node.callee.name === 'require' && path.node.arguments.length) {
        graph.requires.push(path.node.arguments[0].value)
      }
    },
    ImportDeclaration(path) {
      graph.imports.push(path.node.source.value)
    },
    VariableDeclarator(path) {
      if (path.node.id.name) graph.variables.push(path.node.id.name)
    },
    'FunctionDeclaration|ArrowFunctionExpression:exit'(path) {
      currentFunctionStack.pop()
    }
  })

  return graph
}

app.post('/process', async (req, res) => {
  try {
    const { bucket, objectName } = req.body
    const buffer = await getFile(bucket, objectName)
    const code = buffer.toString()

    const analysis = analyzeAST(code)

    const resultName = objectName.replace(/\.[^.]+$/, '.json')

    await minioClient.putObject(
      OUT_BUCKET,
      resultName,
      JSON.stringify(analysis, null, 2),
      { 'Content-Type': 'application/json' }
    )

    res.json({ processedFile: resultName })
  } catch (err) {
    res.status(500).json({ error: err.message })
  }
})

app.listen(4001, async () => {
  await init()
  console.log('Advanced JS AST worker running on 4001')
})
Особенности
Граф функций

functions[name] содержит:

params — список аргументов

calls — какие функции внутри вызываются

parent — имя родительской функции (для вложенных)

Импорты и require

собираются в отдельные массивы, легко строить зависимости между модулями

Переменные

глобальные и локальные (если нужно, можно расширить до scope дерева)

JSON для MinIO

сохранение как hash.json

готов к визуализации или дальнейшему анализу

Масштабируемость

воркер статeless

можно запускать несколько воркеров параллельно

Если хочешь, я могу сразу написать следующую версию воркера с построением полного графа вызовов и вложенных функций в виде DAG, который будет пригоден для визуализации связей в вебе. Это уже будет почти как IDE-уровень анализа.


{
    "error": "Request failed with status code 500"
}

Ошибка 500 — это внутренняя ошибка воркера. Причина почти всегда связана с разбором AST или чтением файла из MinIO.

Для точной диагностики нужно включить логирование ошибок в воркере.

1. Обернуть обработку в try/catch с логом
В app.post('/process'):

app.post('/process', async (req, res) => {
  try {
    const { bucket, objectName } = req.body
    const buffer = await getFile(bucket, objectName)
    const code = buffer.toString()

    let analysis
    try {
      analysis = analyzeAST(code)
    } catch (err) {
      console.error('AST parse error:', err)
      return res.status(500).json({ error: 'AST parse failed', details: err.message })
    }

    const resultName = objectName.replace(/\.[^.]+$/, '.json')

    await minioClient.putObject(
      OUT_BUCKET,
      resultName,
      JSON.stringify(analysis, null, 2),
      { 'Content-Type': 'application/json' }
    )

    res.json({ processedFile: resultName })
  } catch (err) {
    console.error('Worker internal error:', err)
    res.status(500).json({ error: 'Worker failed', details: err.message })
  }
})
2. Потенциальные причины ошибки
Файл не JS/TS (например бинарный) → @babel/parser падает.

Слишком большой файл → превышен лимит памяти.

Плохой путь к MinIO → getFile бросает.

Синтаксическая ошибка в коде → парсер не смог построить AST.

3. Рекомендации
Проверить, что файл реально текстовый JS/TS.

Можно добавить try/catch прямо внутри analyzeAST для игнорирования отдельных узлов.

В логах воркера появится точная причина ошибки.

Если хочешь, я могу переписать воркер, чтобы он не падал на любых файлах, а просто возвращал частичный AST или пустой граф при ошибке синтаксиса. Это гарантирует, что сервер никогда не получит 500.



Advanced JS AST worker running on 4001
AST parse error: Error: You gave us a visitor for the node type ArrowFunctionExpression:exit but it's not a valid type in @babel/traverse 7.29.0
    at verify$1 (C:\Users\ermol\OneDrive\Desktop\Диплом\backend\node_modules\@babel\traverse\lib\visitors.js:105:13)
    at Object.explode$1 [as explode] (C:\Users\ermol\OneDrive\Desktop\Диплом\backend\node_modules\@babel\traverse\lib\visitors.js:41:3)
    at traverse (C:\Users\ermol\OneDrive\Desktop\Диплом\backend\node_modules\@babel\traverse\lib\index.js:52:12)
    at analyzeAST (C:\Users\ermol\OneDrive\Desktop\Диплом\backend\worker-js.js:50:3)
    at C:\Users\ermol\OneDrive\Desktop\Диплом\backend\worker-js.js:100:18
    at process.processTicksAndRejections (node:internal/process/task_queues:95:5)

Ошибка говорит, что запись вида

'ArrowFunctionExpression:exit'(path) { … }
не поддерживается в вашей версии @babel/traverse (7.29.0). Для traverse корректно использовать отдельные функции enter и exit через объект exit внутри visitor.

Нужно заменить:

'FunctionDeclaration|ArrowFunctionExpression:exit'(path) {
  currentFunctionStack.pop()
}
на правильный вариант:

FunctionDeclaration: {
  exit(path) {
    currentFunctionStack.pop()
  }
},
ArrowFunctionExpression: {
  exit(path) {
    currentFunctionStack.pop()
  }
}
То есть visitor теперь выглядит так:

traverse(ast, {
  FunctionDeclaration: {
    enter(path) {
      const name = path.node.id?.name || '<anonymous>'
      const params = path.node.params.map(p => p.name || '<unknown>')
      const parent = currentFunctionStack[currentFunctionStack.length - 1] || null
      graph.functions[name] = { params, calls: [], parent }
      currentFunctionStack.push(name)
    },
    exit(path) {
      currentFunctionStack.pop()
    }
  },
  ArrowFunctionExpression: {
    enter(path) {
      const name = path.node.id?.name || '<arrow>'
      const params = path.node.params.map(p => p.name || '<unknown>')
      const parent = currentFunctionStack[currentFunctionStack.length - 1] || null
      graph.functions[name] = { params, calls: [], parent }
      currentFunctionStack.push(name)
    },
    exit(path) {
      currentFunctionStack.pop()
    }
  },
  CallExpression(path) {
    const callee = path.node.callee.name || path.node.callee?.property?.name || '<unknown>'
    const currentFn = currentFunctionStack[currentFunctionStack.length - 1]
    if (currentFn) graph.functions[currentFn].calls.push(callee)
    if (path.node.callee.name === 'require' && path.node.arguments.length) {
      graph.requires.push(path.node.arguments[0].value)
    }
  },
  ImportDeclaration(path) {
    graph.imports.push(path.node.source.value)
  },
  VariableDeclarator(path) {
    if (path.node.id.name) graph.variables.push(path.node.id.name)
  }
})
После этой правки воркер перестанет падать на :exit.

Запусти заново воркер после правки — ошибки 500 исчезнут.


Посмотри на это const express = require('express')
const Minio = require('minio')
const parser = require('@babel/parser')
const traverse = require('@babel/traverse').default

const app = express()
app.use(express.json())

const minioClient = new Minio.Client({
  endPoint: '127.0.0.1',
  port: 9000,
  useSSL: false,
  accessKey: 'admin',
  secretKey: 'strongpassword'
})

const OUT_BUCKET = 'processedfiles'

async function init() {
  const exists = await minioClient.bucketExists(OUT_BUCKET).catch(() => false)
  if (!exists) await minioClient.makeBucket(OUT_BUCKET)
}

async function getFile(bucket, objectName) {
  const stream = await minioClient.getObject(bucket, objectName)
  return new Promise((resolve, reject) => {
    const chunks = []
    stream.on('data', c => chunks.push(c))
    stream.on('end', () => resolve(Buffer.concat(chunks)))
    stream.on('error', reject)
  })
}

// AST graph builder
function analyzeAST(code) {
  const ast = parser.parse(code, {
    sourceType: 'unambiguous',
    plugins: ['jsx', 'typescript']
  })

  const graph = {
    functions: {}, // {name: {params: [], calls: [], parent: null}}
    imports: [],
    requires: [],
    variables: []
  }

  const currentFunctionStack = []

  traverse(ast, {
    FunctionDeclaration(path) {
      const name = path.node.id?.name || '<anonymous>'
      const params = path.node.params.map(p => p.name || '<unknown>')
      const parent = currentFunctionStack[currentFunctionStack.length - 1] || null

      graph.functions[name] = { params, calls: [], parent }

      currentFunctionStack.push(name)
    },
    ArrowFunctionExpression(path) {
      const name = path.node.id?.name || '<arrow>'
      const params = path.node.params.map(p => p.name || '<unknown>')
      const parent = currentFunctionStack[currentFunctionStack.length - 1] || null

      graph.functions[name] = { params, calls: [], parent }
      currentFunctionStack.push(name)
    },
    CallExpression(path) {
      const callee = path.node.callee.name || path.node.callee?.property?.name || '<unknown>'
      const currentFn = currentFunctionStack[currentFunctionStack.length - 1]
      if (currentFn) {
        graph.functions[currentFn].calls.push(callee)
      }
      if (path.node.callee.name === 'require' && path.node.arguments.length) {
        graph.requires.push(path.node.arguments[0].value)
      }
    },
    ImportDeclaration(path) {
      graph.imports.push(path.node.source.value)
    },
    VariableDeclarator(path) {
      if (path.node.id.name) graph.variables.push(path.node.id.name)
    },
    FunctionDeclaration: {
  exit(path) {
    currentFunctionStack.pop()
  }
},
ArrowFunctionExpression: {
  exit(path) {
    currentFunctionStack.pop()
  }
}
  })

  return graph
}

app.post('/process', async (req, res) => {
  try {
    const { bucket, objectName } = req.body
    const buffer = await getFile(bucket, objectName)
    const code = buffer.toString()

    let analysis
    try {
      analysis = analyzeAST(code)
    } catch (err) {
      console.error('AST parse error:', err)
      return res.status(500).json({ error: 'AST parse failed', details: err.message })
    }

    const resultName = objectName.replace(/\.[^.]+$/, '.json')

    await minioClient.putObject(
      OUT_BUCKET,
      resultName,
      JSON.stringify(analysis, null, 2),
      { 'Content-Type': 'application/json' }
    )

    res.json({ processedFile: resultName })
  } catch (err) {
    console.error('Worker internal error:', err)
    res.status(500).json({ error: 'Worker failed', details: err.message })
  }
})

app.listen(4001, async () => {
  await init()
  console.log('Advanced JS AST worker running on 4001')
})
А тпепрь посмотри на это {
  "functions": {},
  "imports": [],
