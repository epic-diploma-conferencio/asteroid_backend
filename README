Напиши минимальный бэк для работы с базой MinIO для того чтобы я туда мог грузить файлы

Минимальный бэк на Node.js для загрузки файлов в MinIO.

Установка зависимостей
npm init -y
npm install express minio multer
server.js
const express = require('express')
const Minio = require('minio')
const multer = require('multer')

const app = express()
const upload = multer()

// MinIO клиент
const minioClient = new Minio.Client({
  endPoint: 'localhost', // если в docker -> 'minio'
  port: 9000,
  useSSL: false,
  accessKey: 'admin',
  secretKey: 'strongpassword'
})

const BUCKET = 'files'

// создание bucket при старте
async function initBucket() {
  const exists = await minioClient.bucketExists(BUCKET).catch(() => false)
  if (!exists) {
    await minioClient.makeBucket(BUCKET)
  }
}

// загрузка файла
app.post('/upload', upload.single('file'), async (req, res) => {
  try {
    const file = req.file

    const fileName = Date.now() + '_' + file.originalname

    await minioClient.putObject(
      BUCKET,
      fileName,
      file.buffer,
      file.size,
      { 'Content-Type': file.mimetype }
    )

    res.json({
      message: 'uploaded',
      fileName
    })
  } catch (err) {
    res.status(500).json({ error: err.message })
  }
})

// получение файла
app.get('/file/:name', async (req, res) => {
  try {
    const stream = await minioClient.getObject(BUCKET, req.params.name)
    stream.pipe(res)
  } catch (err) {
    res.status(404).json({ error: 'not found' })
  }
})

app.listen(3000, async () => {
  await initBucket()
  console.log('Server started on port 3000')
})
Запуск
node server.js
Загрузка файла (пример через curl)
curl -X POST http://localhost:3000/upload \
  -F "file=@test.png"
Получение файла
http://localhost:3000/file/ИМЯ_ФАЙЛА
Архитектура
HTTP → Express

файл → multer (в памяти)

поток → MinIO

хранение → bucket

Ограничение текущей реализации
файл целиком в RAM (multer memory storage)

нет авторизации

нет валидации

нет сохранения метаданных

Минимальный рабочий слой для интеграции с объектным хранилищем.


